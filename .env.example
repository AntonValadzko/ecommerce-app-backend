PORT=3000
NODE_ENV=development

# App connects through PgBouncer (transaction pooling)
DATABASE_HOST=localhost
DATABASE_PORT=6432
DATABASE_USER=catalog
DATABASE_PASSWORD=catalog
DATABASE_NAME=catalog
# Set true for remote/managed Postgres (RDS, etc.) — required when pg_hba rejects "no encryption"
# DATABASE_SSL=true

OPENSEARCH_ENABLED=true
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_INDEX=products

REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# Database-only mode (see .env.db-only.example and docker-compose.db-only.yml):
# OPENSEARCH_ENABLED=false
# REDIS_ENABLED=false
# DATABASE_PORT=5432

# Swagger UI at /api/docs — on by default in development; set true to enable in production
# SWAGGER_ENABLED=false
